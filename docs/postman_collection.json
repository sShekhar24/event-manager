            "description": "Register a new user in the system"
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    let responseData = pm.response.json();",
                  "    pm.environment.set('accessToken', responseData.data.accessToken);",
                  "    pm.environment.set('refreshToken', responseData.data.refreshToken);",
                  "    pm.environment.set('userId', responseData.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@college.edu\",\n  \"password\": \"Admin123!\"\n}"
            },
            "url": {
